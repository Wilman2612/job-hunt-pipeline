# Copia a .env y rellena. `node --env-file=.env ...` lo carga.

# Postgres + pgvector (coincide con docker-compose.yml; password local, no sensible).
DATABASE_URL=postgres://jobhunt:jobhunt_local@localhost:5433/jobhunt

# Análisis de ofertas con Claude — razonamiento estricto para los hard-stops + JSON estructurado.
ANTHROPIC_API_KEY=
ANALYZE_MODEL=claude-3-5-sonnet-latest

# Matching semántico (embeddings) con OpenAI.
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
