# Copy to .env and fill in. `node --env-file=.env ...` loads it.

# Postgres + pgvector (matches docker-compose.yml; local password, not sensitive).
DATABASE_URL=postgres://jobhunt:jobhunt_local@localhost:5433/jobhunt

# Job posting analysis with Claude — strict reasoning for hard-stops + structured JSON.
ANTHROPIC_API_KEY=
ANALYZE_MODEL=claude-3-5-sonnet-latest

# Semantic matching (embeddings) with OpenAI.
OPENAI_API_KEY=
EMBED_MODEL=text-embedding-3-small
